# ─────────────────────────────────────────────────────────────────────────────
# SnapPass AI Backend — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values. Never commit .env to Git.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=3000
NODE_ENV=development

# Python AI microservice URL
AI_SERVICE_URL=http://localhost:8000

# Upload directory (relative to backend root)
UPLOAD_DIR=uploads

# Max upload size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Allowed CORS origins (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# MongoDB connection string (optional — app works without it for UI-only mode)
MONGO_URI=mongodb://localhost:27017/snappass

# JWT secret for authentication tokens (REQUIRED for auth endpoints)
JWT_SECRET=

# Redis URL for caching and rate limiting (optional — falls back to in-memory)
REDIS_URL=

# Password hashing cost (default: 12 rounds)
BCRYPT_SALT_ROUNDS=12

# Resend API key for transactional emails (optional)
RESEND_API_KEY=
EMAIL_FROM=

# Cloudinary credentials for image hosting (optional — falls back to local storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
